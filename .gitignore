# =============================================
# .gitignore — ArogyaKrishi
# =============================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
build/

# --- Environment & Secrets ---
.env
*.env

# --- Database (SQLite local dev) ---
instance/*.db
instance/*.db-journal

# --- Uploads (user-generated content) ---
uploads/*
!uploads/.gitkeep
!instance/.gitkeep

# --- Large model files ---
model/soilnet_hf/
model/*.h5
model/*.keras
model/*.hdf5
model/*.pt
model/*.pth

# Keep both small pickle models — needed for crop prediction on server
!model/DecisionTree.pkl
!model/crop_disease_prediction_model_using_numeric_values.pkl

# --- Frontend build artifacts ---
frontend/dist/
frontend/node_modules/
node_modules/

# --- Jupyter notebooks ---
notebooks/
.ipynb_checkpoints/

# --- Large static assets ---
static/css/images/
static/images/

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/
*.swp

# --- Logs / Temp ---
*.log
reboot.json
temp_*.wav
temp_*.mp3
temp_kisan_alert_dash/
