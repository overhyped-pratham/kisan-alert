# =============================================
# .env.example — copy to .env and fill in your keys
# NEVER commit the real .env file
# =============================================

# Flask session secret (generate a random string: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret

# Google API Key (Geocoding, Maps)
GOOGLE_API_KEY=your_google_api_key

# Weather API (OpenWeatherMap) — https://openweathermap.org/api
OPEN_WEATHER_APIKEY=your_openweathermap_api_key

# AI Services
GEMINI_API_KEY=your_gemini_api_key
HUGGINGFACE_LOGIN_TOKEN=your_huggingface_token

# ElevenLabs (Speech-to-Text) — https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Expert portal access (comma-separated emails of RSK experts)
EXPERT_EMAILS=expert@krishisaar.ai
