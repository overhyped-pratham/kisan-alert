# =============================================
# .env.example — ArogyaKrishi (KrishiSaar AI)
# Copy to .env and fill in your values.
# NEVER commit the real .env file to git!
# =============================================

# --- Flask ---
SECRET_KEY=change-me-to-a-long-random-secret-key

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://postgres.YOURPROJECT:YOURPASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# --- Google APIs ---
GOOGLE_API_KEY=your_google_api_key

# --- Weather ---
OPEN_WEATHER_APIKEY=your_openweathermap_api_key

# --- AI / LLM ---
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# --- HuggingFace (for offline Whisper STT) ---
HUGGINGFACE_LOGIN_TOKEN=your_hf_token
HF_TOKEN=your_hf_token

# --- ElevenLabs (TTS / Scribe STT) ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# --- Expert portal access (comma-separated emails) ---
EXPERT_EMAILS=expert@krishisaar.ai
